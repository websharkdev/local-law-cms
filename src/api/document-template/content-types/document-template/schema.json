{
  "kind": "collectionType",
  "collectionName": "document_templates",
  "info": {
    "singularName": "document-template",
    "pluralName": "document-templates",
    "displayName": "Document Template",
    "description": "Document type: form fields + generation endpoint"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "self-service",
        "notary-required"
      ],
      "default": "self-service",
      "required": true
    },
    "section": {
      "type": "enumeration",
      "enum": [
        "personal",
        "corporate"
      ],
      "default": "personal",
      "required": true
    },
    "apiType": {
      "type": "enumeration",
      "enum": [
        "employment_contract",
        "nda",
        "service_agreement",
        "partnership_agreement",
        "sales_agreement",
        "lease_agreement",
        "power_of_attorney"
      ],
      "default": "service_agreement",
      "required": true
    },
    "iconKey": {
      "type": "enumeration",
      "enum": [
        "fileText",
        "scale",
        "handshake",
        "scrollText",
        "badgeCheck",
        "copy",
        "file",
        "home",
        "plane",
        "leaf",
        "building2",
        "shield",
        "lightbulb",
        "users"
      ],
      "default": "fileText",
      "required": true
    },
    "active": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "generationUrl": {
      "type": "string"
    },
    "generationMethod": {
      "type": "enumeration",
      "enum": [
        "POST",
        "GET"
      ],
      "default": "POST",
      "required": true
    },
    "generationPayloadTemplate": {
      "type": "json"
    },
    "promptTemplate": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "fields": {
      "type": "component",
      "repeatable": true,
      "component": "doc.field"
    }
  }
}