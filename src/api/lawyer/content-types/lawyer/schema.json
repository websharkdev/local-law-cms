{
  "kind": "collectionType",
  "collectionName": "lawyers_cms",
  "info": {
    "singularName": "lawyer",
    "pluralName": "lawyers",
    "displayName": "Lawyer (CMS)",
    "description": "Marketing profile — kept in sync with Prisma Lawyer table by the read-only bridge (Step 5). Strapi is canonical for displayed image, about copy, notable cases."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "lawyerId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "location": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "specializations": {
      "type": "json"
    },
    "casesCount": {
      "type": "integer",
      "default": 0
    },
    "experienceYears": {
      "type": "integer",
      "default": 0
    },
    "isTopLawyer": {
      "type": "boolean",
      "default": false
    },
    "officePhone": {
      "type": "string"
    },
    "consultationPriceAed": {
      "type": "integer",
      "default": 0
    },
    "about": {
      "type": "richtext"
    },
    "education": {
      "type": "json"
    },
    "notableCases": {
      "type": "json"
    },
    "lawyerStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "hidden",
        "draft"
      ],
      "default": "active"
    },
    "blogArticles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog-article.blog-article",
      "mappedBy": "author"
    }
  }
}