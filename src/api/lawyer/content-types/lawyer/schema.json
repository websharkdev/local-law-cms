{
  "kind": "collectionType",
  "collectionName": "lawyers_cms",
  "info": {
    "singularName": "lawyer",
    "pluralName": "lawyers",
    "displayName": "Lawyer",
    "description": "Lawyer profile — canonical source for catalog, profile page and dashboard Top Lawyers. Publish EN + AR. Use active=false to hide from catalog without deleting."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "lawyerId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "linkedUserEmail": {
      "type": "email"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "firmName": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "location": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "specializations": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tag"
    },
    "casesCount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "experienceYears": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "isTopLawyer": {
      "type": "boolean",
      "default": false
    },
    "active": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "officePhone": {
      "type": "string"
    },
    "contactEmail": {
      "type": "email"
    },
    "whatsapp": {
      "type": "string"
    },
    "consultationPriceAed": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "about": {
      "type": "richtext"
    },
    "education": {
      "type": "component",
      "repeatable": true,
      "component": "lawyer.education-item"
    },
    "notableCases": {
      "type": "component",
      "repeatable": true,
      "component": "lawyer.notable-case"
    },
    "practiceAreas": {
      "type": "component",
      "repeatable": true,
      "component": "lawyer.practice-area"
    },
    "servicesOffered": {
      "type": "component",
      "repeatable": true,
      "component": "lawyer.service-offered"
    },
    "consultationOptions": {
      "type": "component",
      "repeatable": true,
      "component": "lawyer.consultation-option"
    },
    "slotDurationMin": {
      "type": "integer",
      "default": 60,
      "min": 15
    },
    "weeklyHours": {
      "type": "component",
      "repeatable": true,
      "component": "schedule.working-day"
    },
    "timeOff": {
      "type": "component",
      "repeatable": true,
      "component": "schedule.time-off"
    },
    "blogArticles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog-article.blog-article",
      "mappedBy": "author"
    }
  }
}
