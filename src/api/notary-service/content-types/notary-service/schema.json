{
  "kind": "collectionType",
  "collectionName": "notary_services",
  "info": {
    "singularName": "notary-service",
    "pluralName": "notary-services",
    "displayName": "Notary Service",
    "description": "Services available for notary booking"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "description": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "iconKey": {
      "type": "enumeration",
      "enum": [
        "documentAttestation",
        "powerOfAttorney",
        "contractNotarization",
        "authentication",
        "affidavit",
        "other"
      ],
      "default": "other",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "priceAed": {
      "type": "integer",
      "min": 0,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "active": {
      "type": "boolean",
      "default": true,
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "order": {
      "type": "integer",
      "default": 0,
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    }
  }
}
