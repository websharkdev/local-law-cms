# Server
HOST=0.0.0.0
PORT=1337
# PUBLIC_URL=https://cms.example.com
# IS_PROXIED=true   # set when behind a reverse proxy / PaaS (Railway, Render)

# Secrets — generate each with: openssl rand -base64 32
APP_KEYS="key1,key2,key3,key4"
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
# openssl rand -hex 32
ENCRYPTION_KEY=replace_me

# Database
# Local dev (default): sqlite via better-sqlite3
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
# Production (Neon/Railway Postgres):
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:***@host/dbname?sslmode=require
# DATABASE_SSL=true

# App integration — required for CORS + cache revalidation webhook
LOCAL_LAW_URL=http://localhost:3000
STRAPI_WEBHOOK_SECRET=replace_me

# Uploads (production, Cloudflare R2 / S3) — see config/plugins.ts
# AWS_ACCESS_KEY_ID=
# AWS_ACCESS_SECRET=
# AWS_REGION=auto
# AWS_BUCKET=local-law-cms
# AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# AWS_BASE_URL=https://media.example.com   # public R2 domain (custom domain or r2.dev)
